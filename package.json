{
  "name": "grieche-license-server",
  "version": "2.1.1",
  "description": "Central license management server for Meraki CMS",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node init.js && node server.js",
    "dev": "node init.js && node --watch server.js",
    "setup-db": "node setup-db.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "backup": "node -e \"import('./server/backup.js').then(m=>m.runBackup()).then(p=>console.log('Backup:',p))\"",
    "restore": "node restore.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@meraki/plans": "github:stb-srv/meraki-plans",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.16",
    "otplib": "^13.4.0",
    "pdfkit": "^0.15.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jest": "^30.3.0",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2"
  }
}
