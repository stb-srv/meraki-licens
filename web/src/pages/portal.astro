---
import '../styles/tokens.css';
---
<!doctype html>
<html lang="de" data-theme="dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Meraki &ndash; Kunden-Portal</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,300;0,400;0,500;0,700;0,900;1,300;1,400&family=Roboto+Mono:wght@400;500&display=swap"
            rel="stylesheet"
        />
        <style is:global>
            /* design tokens provided globally by tokens.css */
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }
            body {
                background: var(--bg);
                color: var(--text);
                font-family: var(--font-body);
                line-height: 1.6;
                min-height: 100vh;
                transition:
                    background 0.3s,
                    color 0.3s;
            }
            h1,
            h2,
            h3,
            h4,
            h5,
            h6 {
                font-family: var(--font-display);
                letter-spacing: -0.02em;
                line-height: 1.2;
            }
            h1,
            h2 {
                font-weight: 700;
            }
            h3,
            h4 {
                font-weight: 500;
            }
            input,
            button,
            select,
            textarea {
                font-family: var(--font-body);
            }
            button,
            label {
                line-height: 1.4;
                letter-spacing: 0.01em;
            }
            button {
                font-weight: 500;
            }
            .lucide {
                width: 1.05em;
                height: 1.05em;
                vertical-align: -0.18em;
                stroke-width: 2;
                flex-shrink: 0;
            }
            nav {
                position: sticky;
                top: 0;
                z-index: 100;
                background: var(--nav-bg);
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
                border-bottom: 1px solid var(--border);
                padding: 0 var(--space-8);
                display: flex;
                align-items: center;
                justify-content: space-between;
                height: 60px;
            }
            .nav-logo {
                display: inline-flex;
                align-items: center;
                gap: 0.4rem;
                font-size: var(--text-lg);
                font-weight: 700;
                color: var(--accent);
                font-family: var(--font-display);
            }
            .nav-logo .lucide {
                width: 1.15em;
                height: 1.15em;
            }
            .nav-right {
                display: flex;
                gap: 0.8rem;
                align-items: center;
            }
            .btn {
                display: inline-flex;
                align-items: center;
                gap: 0.4rem;
                padding: var(--space-2) var(--space-4);
                border-radius: var(--radius-md);
                border: none;
                cursor: pointer;
                font-size: var(--text-sm);
                font-weight: 500;
                transition: all var(--transition-interactive);
                text-decoration: none;
                font-family: var(--font-body);
            }
            .btn-primary {
                background: var(--accent);
                color: #fff;
            }
            .btn-primary:hover {
                background: var(--accent-hover);
            }
            .btn-ghost {
                background: transparent;
                color: var(--text2);
                border: 1px solid var(--border);
            }
            .btn-ghost:hover {
                border-color: var(--accent);
                color: var(--accent);
            }
            .btn-danger {
                background: var(--accent2);
                color: #fff;
            }
            .btn-danger:hover {
                opacity: 0.85;
            }
            .btn-sm {
                padding: var(--space-1) var(--space-3);
                font-size: var(--text-sm);
            }
            .btn-success {
                background: var(--accent3);
                color: #fff;
            }
            .btn-success:hover {
                opacity: 0.85;
            }
            .page {
                display: none;
            }
            .page.active {
                display: block;
            }
            /* Login & Setup */
            .center-wrap {
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: var(--space-8);
                background: radial-gradient(
                    ellipse 80% 60% at 50% -10%,
                    rgba(0, 191, 165, 0.1),
                    transparent
                );
            }
            .auth-card {
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                padding: var(--space-10) var(--space-8);
                width: 100%;
                max-width: 400px;
                box-shadow: var(--shadow);
            }
            .auth-card h2 {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 0.45rem;
                text-align: center;
                margin-bottom: var(--space-2);
                font-size: var(--text-lg);
            }
            .auth-card h2 .lucide {
                color: var(--accent);
            }
            .auth-card .sub {
                text-align: center;
                color: var(--text2);
                font-size: var(--text-sm);
                margin-bottom: var(--space-6);
            }
            .form-group {
                margin-bottom: var(--space-4);
            }
            .form-group label {
                display: block;
                font-size: var(--text-sm);
                color: var(--text2);
                margin-bottom: var(--space-2);
            }
            .form-group input {
                width: 100%;
                background: var(--bg2);
                border: 1px solid var(--border);
                border-radius: var(--radius-md);
                padding: var(--space-2) var(--space-4);
                color: var(--text);
                font-size: var(--text-sm);
                outline: none;
                transition: border-color 0.2s;
                font-family: var(--font-body);
            }
            .form-group input:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px var(--accent-dim);
            }
            .alert {
                padding: var(--space-3) var(--space-4);
                border-radius: var(--radius-md);
                font-size: var(--text-sm);
                margin-bottom: var(--space-4);
            }
            .alert .lucide {
                color: inherit;
            }
            .alert-error {
                background: rgba(255, 93, 108, 0.1);
                border: 1px solid rgba(255, 93, 108, 0.25);
                color: var(--accent2);
            }
            .alert-success {
                background: rgba(95, 191, 106, 0.1);
                border: 1px solid rgba(95, 191, 106, 0.25);
                color: var(--accent3);
            }
            .alert-info {
                background: var(--accent-dim);
                border: 1px solid rgba(0, 191, 165, 0.25);
                color: var(--accent);
            }
            /* Dashboard */
            .dashboard {
                display: flex;
                min-height: calc(100vh - 60px);
            }
            .sidebar {
                width: 210px;
                background: var(--bg2);
                border-right: 1px solid var(--border);
                padding: var(--space-4) 0;
                flex-shrink: 0;
            }
            .sidebar-brand {
                display: flex;
                align-items: center;
                gap: 0.4rem;
                padding: var(--space-3) var(--space-4) var(--space-4);
                font-size: var(--text-sm);
                font-weight: 700;
                color: var(--accent);
                border-bottom: 1px solid var(--border);
                margin-bottom: var(--space-2);
                font-family: var(--font-display);
            }
            .sidebar-user {
                padding: var(--space-2) var(--space-4) var(--space-3);
                font-size: var(--text-xs);
                color: var(--text2);
            }
            .sidebar-menu {
                list-style: none;
            }
            .sidebar-menu li a {
                display: flex;
                align-items: center;
                gap: 0.6rem;
                padding: var(--space-2) var(--space-4);
                color: var(--text2);
                text-decoration: none;
                font-size: var(--text-sm);
                cursor: pointer;
                transition: all 0.15s;
            }
            .sidebar-menu li a:hover,
            .sidebar-menu li a.active {
                background: var(--accent-dim);
                color: var(--text);
            }
            .sidebar-menu li a.active {
                border-left: 3px solid var(--accent);
            }
            .main-area {
                flex: 1;
                overflow-y: auto;
                padding: var(--space-8) var(--space-8);
            }
            .tab-panel {
                display: none;
            }
            .tab-panel.active {
                display: block;
            }
            .dash-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: var(--space-6);
            }
            .dash-header h2 {
                display: inline-flex;
                align-items: center;
                gap: 0.45rem;
                font-size: var(--text-lg);
            }
            .dash-header h2 .lucide {
                color: var(--accent);
            }
            /* Cards */
            .card {
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                padding: var(--space-6);
                margin-bottom: var(--space-4);
            }
            .card-title {
                display: flex;
                align-items: center;
                gap: 0.4rem;
                font-size: var(--text-sm);
                font-weight: 700;
                letter-spacing: 0.08em;
                color: var(--accent);
                text-transform: uppercase;
                margin-bottom: var(--space-3);
            }
            /* License cards */
            .lic-card {
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                padding: var(--space-6) var(--space-6);
                margin-bottom: var(--space-4);
                transition: border-color 0.2s;
            }
            .lic-card:hover {
                border-color: var(--accent);
            }
            .lic-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                flex-wrap: wrap;
                gap: 0.6rem;
                margin-bottom: var(--space-4);
            }
            .lic-key {
                font-family: var(--font-mono);
                font-size: var(--text-sm);
                background: var(--bg3);
                padding: var(--space-1) var(--space-3);
                border-radius: var(--radius-sm);
                color: var(--accent);
                letter-spacing: 0.08em;
                cursor: pointer;
                user-select: all;
                position: relative;
            }
            .lic-key:hover::after {
                content: 'Kopiert!';
                position: absolute;
                top: -24px;
                left: 50%;
                transform: translateX(-50%);
                background: var(--accent);
                color: #fff;
                font-size: var(--text-xs);
                padding: 0.1rem var(--space-2);
                border-radius: var(--radius-sm);
                white-space: nowrap;
                pointer-events: none;
            }
            .lic-meta {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
                gap: 0.8rem;
                margin-bottom: var(--space-4);
            }
            .lic-meta-item .lmi-label {
                font-size: var(--text-xs);
                color: var(--text2);
            }
            .lic-meta-item .lmi-value {
                font-size: var(--text-sm);
                font-weight: 500;
            }
            .domain-form {
                display: flex;
                gap: 0.6rem;
                align-items: center;
                flex-wrap: wrap;
                margin-top: var(--space-3);
                padding-top: var(--space-3);
                border-top: 1px solid var(--border);
            }
            .domain-form input {
                background: var(--bg2);
                border: 1px solid var(--border);
                border-radius: var(--radius-md);
                padding: var(--space-2) var(--space-3);
                color: var(--text);
                font-size: var(--text-sm);
                outline: none;
                flex: 1;
                min-width: 180px;
                font-family: var(--font-body);
            }
            .domain-form input:focus {
                border-color: var(--accent);
            }
            .domain-msg {
                font-size: var(--text-sm);
                margin-top: var(--space-2);
            }
            /* Table */
            .table-wrap {
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                overflow: auto;
            }
            table.data-table {
                width: 100%;
                border-collapse: collapse;
                font-size: var(--text-sm);
            }
            table.data-table th {
                background: var(--bg3);
                padding: var(--space-3) var(--space-4);
                text-align: left;
                color: var(--text2);
                font-weight: 500;
                white-space: nowrap;
            }
            table.data-table td {
                padding: var(--space-2) var(--space-4);
                border-bottom: 1px solid var(--border);
                vertical-align: middle;
            }
            table.data-table tr:last-child td {
                border: none;
            }
            table.data-table tr:hover td {
                background: var(--bg3);
            }
            table.data-table code {
                font-family: var(--font-mono);
            }
            .badge {
                display: inline-block;
                padding: 0.15rem var(--space-2);
                border-radius: 999px;
                font-size: var(--text-xs);
                font-weight: 700;
            }
            .badge-active {
                background: rgba(95, 191, 106, 0.15);
                color: var(--accent3);
            }
            .badge-revoked,
            .badge-cancelled,
            .badge-suspended,
            .badge-expired {
                background: rgba(255, 93, 108, 0.15);
                color: var(--accent2);
            }
            .badge-FREE {
                background: rgba(139, 144, 153, 0.15);
                color: var(--text2);
            }
            .badge-BASIC,
            .badge-STARTER {
                background: rgba(95, 191, 106, 0.2);
                color: var(--accent3);
            }
            .badge-PRO,
            .badge-PRO_PLUS {
                background: rgba(0, 191, 165, 0.2);
                color: var(--accent);
            }
            .badge-ENTERPRISE {
                background: rgba(232, 175, 52, 0.15);
                color: var(--gold);
            }
            .badge-purchase {
                background: rgba(95, 191, 106, 0.15);
                color: var(--accent3);
            }
            .badge-renewal {
                background: rgba(0, 191, 165, 0.15);
                color: var(--accent);
            }
            .badge-upgrade {
                background: rgba(232, 175, 52, 0.15);
                color: var(--gold);
            }
            .badge-downgrade,
            .badge-cancellation {
                background: rgba(255, 93, 108, 0.15);
                color: var(--accent2);
            }
            .loading {
                text-align: center;
                padding: var(--space-12);
                color: var(--text2);
            }
            .spinner {
                display: inline-block;
                width: 24px;
                height: 24px;
                border: 3px solid var(--border);
                border-top-color: var(--accent);
                border-radius: 50%;
                animation: spin 0.7s linear infinite;
            }
            @keyframes spin {
                to {
                    transform: rotate(360deg);
                }
            }
            .theme-toggle {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                background: transparent;
                border: 1px solid var(--border);
                color: var(--text2);
                border-radius: var(--radius-md);
                width: 32px;
                height: 32px;
                cursor: pointer;
                transition: all 0.2s;
            }
            .theme-toggle:hover {
                border-color: var(--accent);
                color: var(--accent);
            }
            @media (max-width: 650px) {
                .sidebar {
                    width: 46px;
                }
                .sidebar-brand span,
                .sidebar-user,
                .sidebar-menu li a span {
                    display: none;
                }
                .sidebar-menu li a {
                    justify-content: center;
                    padding: var(--space-3);
                }
                .main-area {
                    padding: var(--space-4);
                }
            }
            /* Shop / Plan-Cards */
            .plan-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
                gap: 1.2rem;
                margin-top: var(--space-4);
            }
            .plan-card {
                background: var(--card);
                border: 2px solid var(--border);
                border-radius: var(--radius);
                padding: var(--space-6) var(--space-6);
                display: flex;
                flex-direction: column;
                transition:
                    border-color 0.2s,
                    box-shadow 0.2s;
                position: relative;
            }
            .plan-card:hover {
                border-color: var(--accent);
                box-shadow: 0 4px 18px rgba(0, 191, 165, 0.15);
            }
            .plan-card.popular {
                border-color: var(--accent);
            }
            .plan-popular-badge {
                position: absolute;
                top: -12px;
                left: 50%;
                transform: translateX(-50%);
                background: var(--accent);
                color: #fff;
                font-size: var(--text-xs);
                font-weight: 700;
                padding: var(--space-1) var(--space-3);
                border-radius: var(--radius-xl);
                white-space: nowrap;
                display: inline-flex;
                align-items: center;
                gap: 0.25rem;
            }
            .plan-name {
                font-family: var(--font-display);
                font-size: var(--text-base);
                font-weight: 700;
                margin-bottom: var(--space-1);
            }
            .plan-desc {
                color: var(--text2);
                font-size: var(--text-sm);
                margin-bottom: var(--space-4);
                line-height: 1.5;
                flex: 1;
            }
            .plan-price {
                font-family: var(--font-display);
                font-size: var(--text-xl);
                font-weight: 700;
                color: var(--accent);
                line-height: 1;
            }
            .plan-price span {
                font-size: var(--text-sm);
                font-weight: 400;
                color: var(--text2);
            }
            .plan-features {
                list-style: none;
                margin: var(--space-4) 0 var(--space-4);
                font-size: var(--text-sm);
                display: flex;
                flex-direction: column;
                gap: 0.4rem;
            }
            .plan-features li::before {
                content: '✓ ';
                color: var(--accent3);
                font-weight: 700;
            }
            .plan-features li.no::before {
                content: '✗ ';
                color: var(--text2);
            }
            .plan-features li.no {
                color: var(--text2);
            }
            /* Order modal */
            .modal-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0, 0, 0, 0.6);
                backdrop-filter: blur(2px);
                z-index: 200;
                align-items: center;
                justify-content: center;
            }
            .modal-overlay.open {
                display: flex;
            }
            .modal-box {
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                padding: var(--space-8);
                width: 100%;
                max-width: 420px;
                box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
            }
            .modal-box h3 {
                display: flex;
                align-items: center;
                gap: 0.45rem;
                font-family: var(--font-display);
                margin-bottom: var(--space-4);
            }
            .modal-box h3 .lucide {
                color: var(--accent);
            }
            .modal-footer {
                display: flex;
                gap: 0.7rem;
                justify-content: flex-end;
                margin-top: var(--space-6);
            }
            code {
                font-family: var(--font-mono);
            }
            #toast-container {
                position: fixed;
                bottom: var(--space-6);
                right: var(--space-6);
                z-index: 9999;
                display: flex;
                flex-direction: column;
                gap: 0.5rem;
                pointer-events: none;
            }
            .toast {
                padding: var(--space-3) var(--space-4);
                border-radius: var(--radius-md);
                font-size: var(--text-sm);
                font-weight: 500;
                max-width: 340px;
                box-shadow: 0 4px 16px rgba(0, 0, 0, 0.35);
                opacity: 1;
                transform: translateY(0);
                transition:
                    opacity 0.35s,
                    transform 0.35s;
                pointer-events: all;
            }
            .toast-out {
                opacity: 0;
                transform: translateY(8px);
            }
            .toast-success {
                background: rgba(95, 191, 106, 0.15);
                border: 1px solid rgba(95, 191, 106, 0.35);
                color: var(--accent3);
            }
            .toast-error {
                background: rgba(255, 93, 108, 0.15);
                border: 1px solid rgba(255, 93, 108, 0.35);
                color: var(--accent2);
            }
            .toast-info {
                background: var(--accent-dim);
                border: 1px solid rgba(0, 191, 165, 0.25);
                color: var(--accent);
            }
            .skel-box {
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                padding: var(--space-6);
                margin-bottom: var(--space-4);
            }
            .skel-line {
                background: linear-gradient(
                    90deg,
                    var(--bg3) 25%,
                    var(--border) 50%,
                    var(--bg3) 75%
                );
                background-size: 200% 100%;
                animation: skel-shimmer 1.4s infinite;
                border-radius: var(--radius-sm);
                height: 14px;
                margin-bottom: var(--space-3);
            }
            .skel-line.wide {
                width: 70%;
            }
            .skel-line.mid {
                width: 45%;
            }
            .skel-line.short {
                width: 30%;
            }
            @keyframes skel-shimmer {
                0% {
                    background-position: 200% 0;
                }
                100% {
                    background-position: -200% 0;
                }
            }
            .stats-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
                gap: 0.8rem;
                margin-bottom: var(--space-6);
            }
            .stat-card {
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                padding: var(--space-4);
                text-align: center;
            }
            .stat-val {
                font-size: var(--text-xl);
                font-weight: 700;
                color: var(--accent);
                line-height: 1.1;
            }
            .stat-lbl {
                font-size: var(--text-xs);
                color: var(--text2);
                margin-top: var(--space-1);
            }
        </style>
    </head>
    <body>
        <nav id="portal-nav" style="display: none">
            <span
                class="nav-logo"
                onclick="window.location.href = '/'"
                style="cursor: pointer"
                title="Zur Startseite"
                ><img
                    src="/Meraki_RMS_CMS.png"
                    alt="Meraki"
                    style="height: 26px; width: auto; display: block"
                />
                <span style="font-size: var(--text-sm)">Kunden-Portal</span></span
            >
            <div class="nav-right">
                <button
                    class="theme-toggle"
                    onclick="toggleTheme()"
                    id="theme-btn"
                    title="Theme wechseln"
                >
                    <i data-lucide="sun"></i>
                </button>
                <span
                    id="nav-customer-name"
                    style="font-size: var(--text-sm); color: var(--text2)"
                ></span>
                <button class="btn btn-ghost btn-sm" onclick="doLogout()">
                    <i data-lucide="log-out"></i> Logout
                </button>
            </div>
        </nav>

