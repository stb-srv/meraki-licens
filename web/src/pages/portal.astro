        <script is:inline>
            // Lucide-Icons in dynamisch erzeugtem Markup automatisch rendern
            (function () {
                var pending = false;
                function refresh() {
                    if (pending) return;
                    pending = true;
                    requestAnimationFrame(function () {
                        pending = false;
                        if (window.lucide) window.lucide.createIcons();
                    });
                }
                function start() {
                    if (window.lucide) window.lucide.createIcons();
                    new MutationObserver(refresh).observe(document.body, {
                        childList: true,
                        subtree: true,
                    });
                }
                if (document.readyState !== 'loading') start();
                else document.addEventListener('DOMContentLoaded', start);
            })();

            function setThemeIcon(theme) {
                var btn = document.getElementById('theme-btn');
                if (btn)
                    btn.innerHTML =
                        theme === 'dark'
                            ? '<i data-lucide="sun"></i>'
                            : '<i data-lucide="moon"></i>';
                if (window.lucide) window.lucide.createIcons();
            }

            (function () {
                var t = localStorage.getItem('theme') || 'dark';
                document.documentElement.setAttribute('data-theme', t);
                setThemeIcon(t);
            })();
            function toggleTheme() {
                var cur = document.documentElement.getAttribute('data-theme') || 'dark';
                var next = cur === 'dark' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-theme', next);
                localStorage.setItem('theme', next);
                setThemeIcon(next);
            }

            var TOKEN = sessionStorage.getItem('portal_token') || '';
            var CUSTOMER = null;

            function API(path, opts) {
                opts = opts || {};
                var headers = { 'Content-Type': 'application/json' };
                if (TOKEN) headers['Authorization'] = 'Bearer ' + TOKEN;
                return fetch('/api/portal' + path, Object.assign({ headers: headers }, opts)).then(
                    function (r) {
                        return r.json().then(function (d) {
                            if (!r.ok) throw d;
                            return d;
                        });
                    }
                );
            }

            function esc(s) {
                return String(s || '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;');
            }
            function fmtDate(d) {
                return d
                    ? new Date(d).toLocaleString('de-DE', {
                          day: '2-digit',
                          month: '2-digit',
                          year: 'numeric',
                          hour: '2-digit',
                          minute: '2-digit',
                      })
                    : '—';
            }
            function fmtDateShort(d) {
                return d
                    ? new Date(d).toLocaleDateString('de-DE', {
                          day: '2-digit',
                          month: '2-digit',
                          year: 'numeric',
                      })
                    : '—';
            }
            function daysLeft(d) {
                return Math.ceil((new Date(d) - Date.now()) / 86400000);
            }
            function fmtEur(v) {
                return v != null && v !== '' ? parseFloat(v).toFixed(2) + ' €' : '—';
            }

            function showAlert(elId, msg, type) {
                var el = document.getElementById(elId);
                if (el)
                    el.innerHTML =
                        '<div class="alert alert-' + (type || 'error') + '">' + msg + '</div>';
            }

            function toast(msg, type) {
                var c = document.getElementById('toast-container');
                if (!c) return;
                var t = document.createElement('div');
                t.className = 'toast toast-' + (type || 'info');
                t.textContent = msg;
                c.appendChild(t);
                setTimeout(function () {
                    t.classList.add('toast-out');
                    setTimeout(function () {
                        t.remove();
                    }, 350);
                }, 4000);
            }

            var _upgradeLicenseKey = '';
            function openUpgradeModal(key, currentType) {
                _upgradeLicenseKey = key;
                document.getElementById('upgrade-current-plan').textContent = currentType;
                document.getElementById('upgrade-alert').innerHTML = '';
                document.getElementById('upgrade-confirm-btn').disabled = false;
                var sel = document.getElementById('upgrade-plan-select');
                var order = { FREE: 0, TRIAL: 0, STARTER: 1, PRO: 2, PRO_PLUS: 3, ENTERPRISE: 4 };
                var cur = order[currentType] || 0;
                for (var i = 0; i < sel.options.length; i++) {
                    sel.options[i].disabled = (order[sel.options[i].value] || 0) <= cur;
                }
                sel.value = sel.options[Math.min(cur, sel.options.length - 1)].value;
                for (var j = 0; j < sel.options.length; j++) {
                    if (!sel.options[j].disabled) {
                        sel.value = sel.options[j].value;
                        break;
                    }
                }
                document.getElementById('upgrade-modal').classList.add('open');
                if (window.lucide) window.lucide.createIcons();
            }
            function closeUpgradeModal() {
                document.getElementById('upgrade-modal').classList.remove('open');
            }
            function confirmUpgrade() {
                var newType = document.getElementById('upgrade-plan-select').value;
                var btn = document.getElementById('upgrade-confirm-btn');
                btn.disabled = true;
                btn.textContent = 'Wird gesendet…';
                API('/licenses/' + encodeURIComponent(_upgradeLicenseKey) + '/upgrade', {
                    method: 'POST',
                    body: JSON.stringify({ new_type: newType }),
                })
                    .then(function () {
                        closeUpgradeModal();
                        toast('Lizenz erfolgreich auf ' + newType + ' upgraded!', 'success');
                        loadLicenses();
                    })
                    .catch(function (e) {
                        document.getElementById('upgrade-alert').innerHTML =
                            '<div style="color:var(--accent2);font-size: var(--text-sm)">' +
                            esc(e.message || 'Fehler beim Upgrade.') +
                            '</div>';
                        btn.disabled = false;
                        btn.innerHTML = '<i data-lucide="arrow-up-circle"></i> Upgrade bestätigen';
                        if (window.lucide) window.lucide.createIcons();
                    });
            }

            function renewLicense(key) {
                if (
                    !confirm(
                        'Lizenz um einen weiteren Lizenzzeitraum verlängern? Es wird eine neue Rechnung erstellt.'
                    )
                )
                    return;
                API('/licenses/' + encodeURIComponent(key) + '/renew', { method: 'POST' })
                    .then(function (d) {
                        toast(
                            'Lizenz verlängert bis ' +
                                new Date(d.new_expiry).toLocaleDateString('de-DE') +
                                '.',
                            'success'
                        );
                        loadLicenses();
                    })
                    .catch(function (e) {
                        toast(e.message || 'Fehler beim Verlängern.', 'error');
                    });
            }

            function loadLicenseStats() {
                var el = document.getElementById('lic-stats-row');
                if (!el) return;
                API('/stats')
                    .then(function (d) {
                        var s = d.stats || {};
                        el.innerHTML =
                            '<div class="stats-grid">' +
                            '<div class="stat-card"><div class="stat-val">' +
                            esc(s.active_licenses || 0) +
                            '</div><div class="stat-lbl">Aktive Lizenzen</div></div>' +
                            '<div class="stat-card"><div class="stat-val">' +
                            esc(s.total_validations || 0) +
                            '</div><div class="stat-lbl">Validierungen gesamt</div></div>' +
                            '<div class="stat-card"><div class="stat-val">' +
                            esc(s.active_devices || 0) +
                            '</div><div class="stat-lbl">Aktive Geräte</div></div>' +
                            (s.top_features && s.top_features.length
                                ? '<div class="stat-card"><div class="stat-val" style="font-size: var(--text-base)">' +
                                  esc(s.top_features[0].name) +
                                  '</div><div class="stat-lbl">Meist genutztes Feature</div></div>'
                                : '') +
                            '</div>';
                    })
                    .catch(function () {
                        el.innerHTML = '';
                    });
            }

            function showPage(name) {
                document.querySelectorAll('.page').forEach(function (p) {
                    p.classList.remove('active');
                });
                var pg = document.getElementById('page-' + name);
                if (pg) pg.classList.add('active');
                document.getElementById('portal-nav').style.display =
                    name === 'dashboard' ? '' : 'none';
            }

            function switchTab(name) {
                document.querySelectorAll('.tab-panel').forEach(function (p) {
                    p.classList.remove('active');
                });
                document.querySelectorAll('.sidebar-menu li a').forEach(function (a) {
                    a.classList.remove('active');
                });
                var tp = document.getElementById('tab-' + name);
                if (tp) tp.classList.add('active');
                var tb = document.getElementById('stab-' + name);
                if (tb) tb.classList.add('active');
                if (name === 'licenses') loadLicenses();
                else if (name === 'shop') loadShop();
                else if (name === 'invoices') loadPortalInvoices();
                else if (name === 'history') loadHistory();
                else if (name === 'account') loadAccount();
            }

            // ── Startup: invite token prüfen ──────────────────────────────────────────────
            function init() {
                var params = new URLSearchParams(window.location.search);

                // E-Mail-Verifizierung über Hash oder Query
                var verifyToken = '';
                if (window.location.hash && window.location.hash.indexOf('#verify') === 0) {
                    var hashQuery = window.location.hash.split('?')[1];
                    if (hashQuery) {
                        var hashParams = new URLSearchParams(hashQuery);
                        verifyToken = hashParams.get('token') || '';
                    }
                } else if (params.get('verify_token')) {
                    verifyToken = params.get('verify_token');
                }

                if (verifyToken) {
                    showPage('verify');
                    fetch('/api/portal/verify-email', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ token: verifyToken }),
                    })
                        .then(function (r) {
                            return r.json().then(function (d) {
                                if (!r.ok) throw d;
                                return d;
                            });
                        })
                        .then(function (d) {
                            document.getElementById('verify-spinner').style.display = 'none';
                            showAlert(
                                'verify-alert',
                                '<i data-lucide="check-circle"></i> ' +
                                    esc(d.message || 'E-Mail erfolgreich verifiziert!'),
                                'success'
                            );
                            document.getElementById('verify-text').innerHTML =
                                'Du wirst in Kürze zum Login weitergeleitet...';
                            document.getElementById('verify-login-link').style.display = 'block';
                            setTimeout(function () {
                                window.location.href = '/login';
                            }, 3000);
                        })
                        .catch(function (e) {
                            document.getElementById('verify-spinner').style.display = 'none';
                            showAlert(
                                'verify-alert',
                                esc(e.message || 'Verifizierung fehlgeschlagen.'),
                                'error'
                            );
                            document.getElementById('verify-text').innerHTML =
                                'Der Bestätigungslink ist ungültig oder abgelaufen.';
                            document.getElementById('verify-login-link').style.display = 'block';
                            setTimeout(function () {
                                window.location.href = '/login';
                            }, 4000);
                        });
                    return;
                }

                var inviteToken = params.get('token');
                if (inviteToken) {
                    showPage('setup');
                    // Token vorab verifizieren
                    fetch(
                        '/api/portal/verify-invite-token?token=' + encodeURIComponent(inviteToken)
                    )
                        .then(function (r) {
                            return r.json();
                        })
                        .then(function (d) {
                            if (d.success) {
                                document.getElementById('setup-name-hint').textContent =
                                    'Willkommen, ' +
                                    d.name +
                                    '! Bitte setze ein Passwort für ' +
                                    d.email +
                                    '.';
                            } else {
                                showAlert('setup-alert', esc(d.message), 'error');
                            }
                        });
                    window._inviteToken = inviteToken;
                    return;
                }
                if (TOKEN) {
                    // Token noch gültig?
                    API('/me')
                        .then(function (d) {
                            CUSTOMER = d.customer;
                            showDashboard();
                        })
                        .catch(function (e) {
                            if (e && e.must_change_password) {
                                showPage('change-password');
                            } else {
                                TOKEN = '';
                                sessionStorage.removeItem('portal_token');
                                window.location.href = '/login';
                            }
                        });
                } else {
                    // No token: redirect to central login page
                    // But allow setup page (invite token) to stay
                    var params = new URLSearchParams(window.location.search);
                    if (!params.get('token')) {
                        window.location.href = '/login';
                        return;
                    }
                    showPage('login');
                }
            }

            function showDashboard() {
                document.getElementById('portal-nav').style.display = '';
                document.getElementById('nav-customer-name').textContent = CUSTOMER.name;
                document.getElementById('sb-customer').textContent = CUSTOMER.name;
                showPage('dashboard');
                loadLicenses();
            }

            // ── Login (removed — handled by login.html) ──────────────────────────────────

            // ── Setup Password ────────────────────────────────────────────────────────────
            function doSetupPassword() {
                var pass = document.getElementById('setup-pass').value;
                var pass2 = document.getElementById('setup-pass2').value;
                if (pass.length < 10) {
                    showAlert('setup-alert', 'Passwort muss mindestens 10 Zeichen haben.', 'error');
                    return;
                }
                if (pass !== pass2) {
                    showAlert('setup-alert', 'Passwörter stimmen nicht überein.', 'error');
                    return;
                }
                showAlert('setup-alert', 'Passwort wird gesetzt&hellip;', 'info');
                fetch('/api/portal/setup-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token: window._inviteToken, password: pass }),
                })
                    .then(function (r) {
                        return r.json();
                    })
                    .then(function (d) {
                        if (d.success) {
                            showAlert(
                                'setup-alert',
                                '<i data-lucide="check-circle"></i> ' +
                                    esc(d.message) +
                                    ' Du wirst weitergeleitet&hellip;',
                                'success'
                            );
                            setTimeout(function () {
                                window.location.href = '/login';
                            }, 2000);
                        } else {
                            showAlert('setup-alert', esc(d.message), 'error');
                        }
                    })
                    .catch(function (e) {
                        showAlert('setup-alert', esc(e.message || 'Fehler'), 'error');
                    });
            }

            function doChangePasswordForced() {
                var curr = document.getElementById('change-pass-curr').value;
                var newp = document.getElementById('change-pass-new').value;
                var newp2 = document.getElementById('change-pass-new2').value;
                if (!curr || !newp || !newp2) {
                    showAlert('change-pass-alert', 'Bitte alle Felder ausfüllen.', 'error');
                    return;
                }
                if (newp.length < 10) {
                    showAlert(
                        'change-pass-alert',
                        'Das neue Passwort muss mindestens 10 Zeichen haben.',
                        'error'
                    );
                    return;
                }
                if (newp !== newp2) {
                    showAlert(
                        'change-pass-alert',
                        'Die neuen Passwörter stimmen nicht überein.',
                        'error'
                    );
                    return;
                }
                if (curr === newp) {
                    showAlert(
                        'change-pass-alert',
                        'Das neue Passwort muss sich vom aktuellen unterscheiden.',
                        'error'
                    );
                    return;
                }

                showAlert('change-pass-alert', 'Passwort wird geändert...', 'info');

                API('/change-password', {
                    method: 'POST',
                    body: JSON.stringify({ current_password: curr, new_password: newp }),
                })
                    .then(function (d) {
                        showAlert(
                            'change-pass-alert',
                            '<i data-lucide="check-circle"></i> Passwort geändert! Du wirst eingeloggt...',
                            'success'
                        );
                        setTimeout(function () {
                            document.getElementById('change-pass-curr').value = '';
                            document.getElementById('change-pass-new').value = '';
                            document.getElementById('change-pass-new2').value = '';
                            init();
                        }, 2000);
                    })
                    .catch(function (e) {
                        showAlert(
                            'change-pass-alert',
                            esc(e.message || 'Fehler beim Passwort-Ändern.'),
                            'error'
                        );
                    });
            }

            // ── Logout ────────────────────────────────────────────────────────────────────
            function doLogout() {
                if (TOKEN) {
                    API('/logout', { method: 'POST' }).catch(function () {});
                }
                TOKEN = '';
                CUSTOMER = null;
                sessionStorage.removeItem('portal_token');
                showPage('login');
            }

            // ── Lizenzen ──────────────────────────────────────────────────────────────────
            function loadLicenses() {
                document.getElementById('lic-list').innerHTML =
                    '<div class="skel-box"><div class="skel-line wide"></div><div class="skel-line mid"></div><div class="skel-line short"></div></div><div class="skel-box"><div class="skel-line wide"></div><div class="skel-line mid"></div></div>';
                loadLicenseStats();
                API('/licenses')
                    .then(function (d) {
                        var lics = d.licenses || [];
                        if (!lics.length) {
                            document.getElementById('lic-list').innerHTML =
                                '<div class="loading">Keine Lizenzen gefunden.</div>';
                            return;
                        }
                        document.getElementById('lic-list').innerHTML = lics
                            .map(function (l) {
                                var days = daysLeft(l.expires_at);
                                var daysColor =
                                    days < 0
                                        ? 'color:var(--accent2)'
                                        : days < 30
                                          ? 'color:var(--gold)'
                                          : '';
                                var statusBadge =
                                    '<span class="badge badge-' +
                                    esc(l.status) +
                                    '">' +
                                    esc(l.status) +
                                    '</span>';
                                var typeBadge =
                                    '<span class="badge badge-' +
                                    esc(l.type) +
                                    '">' +
                                    esc(l.type) +
                                    '</span>';
                                var warnHtml =
                                    days > 0 && days <= 30
                                        ? '<div style="background:var(--accent-dim);color:var(--gold);border-radius: var(--radius-sm);padding: var(--space-2) var(--space-3);font-size: var(--text-sm);margin-bottom: var(--space-4)"><i data-lucide="alert-triangle"></i> Läuft in ' +
                                          days +
                                          ' Tagen ab</div>'
                                        : days <= 0
                                          ? '<div style="background:rgba(255,93,108,.1);color:var(--accent2);border-radius: var(--radius-sm);padding: var(--space-2) var(--space-3);font-size: var(--text-sm);margin-bottom: var(--space-4)"><i data-lucide="x-circle"></i> Abgelaufen</div>'
                                          : '';
                                return (
                                    '<div class="lic-card">' +
                                    '<div class="lic-header" style="margin-bottom:' +
                                    (warnHtml ? '.5rem' : '1rem') +
                                    '">' +
                                    '<div>' +
                                    '<div style="font-size: var(--text-xs);color:var(--text2);margin-bottom: var(--space-1)">Lizenzschlüssel (klicken zum Kopieren)</div>' +
                                    '<div class="lic-key" onclick="copyKey(this,\'' +
                                    esc(l.license_key) +
                                    '\')" title="Klicken zum Kopieren">' +
                                    esc(l.license_key) +
                                    '</div>' +
                                    '</div>' +
                                    '<div style="display:flex;gap:.5rem;align-items:center">' +
                                    typeBadge +
                                    statusBadge +
                                    '</div>' +
                                    '</div>' +
                                    warnHtml +
                                    '<div class="lic-meta">' +
                                    '<div class="lic-meta-item"><div class="lmi-label">Ablaufdatum</div><div class="lmi-value" style="' +
                                    daysColor +
                                    '">' +
                                    fmtDateShort(l.expires_at) +
                                    '</div></div>' +
                                    '<div class="lic-meta-item"><div class="lmi-label">Verbleibend</div><div class="lmi-value" style="' +
                                    daysColor +
                                    '">' +
                                    (days >= 0 ? days + ' Tage' : 'Abgelaufen') +
                                    '</div></div>' +
                                    '<div class="lic-meta-item"><div class="lmi-label">Domain</div><div class="lmi-value">' +
                                    esc(l.associated_domain || '*') +
                                    '</div></div>' +
                                    '<div class="lic-meta-item"><div class="lmi-label">Validierungen</div><div class="lmi-value">' +
                                    esc(l.usage_count || 0) +
                                    '</div></div>' +
                                    '</div>' +
                                    '<div class="domain-form">' +
                                    '<span style="font-size: var(--text-sm);color:var(--text2);white-space:nowrap"><i data-lucide="globe"></i> Domain binden:</span>' +
                                    '<input type="text" placeholder="meinrestaurant.de" id="dom-' +
                                    esc(l.license_key) +
                                    '" value="' +
                                    (l.associated_domain && l.associated_domain !== '*'
                                        ? esc(l.associated_domain)
                                        : '') +
                                    '" style="max-width:280px">' +
                                    '<button class="btn btn-primary btn-sm" onclick="saveDomain(\'' +
                                    esc(l.license_key) +
                                    '\')" >Speichern</button>' +
                                    '<span class="domain-msg" id="dom-msg-' +
                                    esc(l.license_key) +
                                    '"></span>' +
                                    '</div>' +
                                    ((l.status === 'active' || l.status === 'expired') &&
                                    l.type !== 'FREE' &&
                                    l.type !== 'TRIAL'
                                        ? '<div style="margin-top: var(--space-3);padding-top: var(--space-3);border-top:1px solid var(--border);display:flex;gap:.6rem;flex-wrap:wrap">' +
                                          (l.status === 'active' && l.type !== 'ENTERPRISE'
                                              ? '<button class="btn btn-ghost btn-sm" onclick="openUpgradeModal(\'' +
                                                esc(l.license_key) +
                                                "','" +
                                                esc(l.type) +
                                                '\')"><i data-lucide="arrow-up-circle"></i> Upgraden</button>'
                                              : '') +
                                          '<button class="btn btn-ghost btn-sm" onclick="renewLicense(\'' +
                                          esc(l.license_key) +
                                          '\')"><i data-lucide="refresh-cw"></i> Verlängern</button>' +
                                          '</div>'
                                        : '') +
                                    '</div>'
                                );
                            })
                            .join('');
                    })
                    .catch(function (e) {
                        document.getElementById('lic-list').innerHTML =
                            '<div class="alert alert-error">' +
                            esc(e.message || 'Fehler beim Laden.') +
                            '</div>';
                    });
            }

            function copyKey(el, key) {
                navigator.clipboard
                    .writeText(key)
                    .then(function () {
                        var orig = el.textContent;
                        el.textContent = '✓ Kopiert!';
                        setTimeout(function () {
                            el.textContent = orig;
                        }, 1500);
                    })
                    .catch(function () {});
            }

            function saveDomain(key) {
                var input = document.getElementById('dom-' + key);
                var msg = document.getElementById('dom-msg-' + key);
                var domain = input ? input.value.trim() : '';
                if (!domain) {
                    msg.style.color = 'var(--accent2)';
                    msg.textContent = 'Bitte Domain eingeben.';
                    return;
                }
                msg.style.color = 'var(--text2)';
                msg.textContent = 'Speichert…';
                API('/licenses/' + encodeURIComponent(key) + '/domain', {
                    method: 'PATCH',
                    body: JSON.stringify({ domain: domain }),
                })
                    .then(function (d) {
                        msg.style.color = 'var(--accent3)';
                        msg.textContent = '✓ ' + esc(d.domain) + ' gespeichert.';
                    })
                    .catch(function (e) {
                        msg.style.color = 'var(--accent2)';
                        msg.textContent = '✗ ' + esc(e.message || 'Fehler');
                    });
            }

            // ── Shop ──────────────────────────────────────────────────────────────────────
            var _selectedPlan = null;
            var _shopPlansMap = {}; // plan_id → plan object, sicherer als JSON.stringify im onclick

            function loadShop() {
                var el = document.getElementById('shop-content');
                el.innerHTML = '<div class="loading"><div class="spinner"></div></div>';
                API('/plans')
                    .then(function (d) {
                        var plans = d.plans || [];
                        if (!plans.length) {
                            el.innerHTML =
                                '<p style="color:var(--text2)">Keine Pläne verfügbar.</p>';
                            return;
                        }
                        _shopPlansMap = {};
                        plans.forEach(function (p) {
                            _shopPlansMap[p.plan_id] = p;
                        });
                        el.innerHTML =
                            '<div class="plan-grid">' +
                            plans
                                .map(function (p) {
                                    var feats = p.features || [];
                                    if (typeof feats === 'string') {
                                        try {
                                            feats = JSON.parse(feats);
                                        } catch (e) {
                                            feats = [];
                                        }
                                    }
                                    var isPopular = p.plan_id === 'PRO';
                                    var price = parseFloat(p.price) || 0;
                                    var priceHtml =
                                        price === 0
                                            ? '<div class="plan-price">Kostenlos</div>'
                                            : '<div class="plan-price">' +
                                              price.toFixed(0) +
                                              ' €<span> / Jahr</span></div>';
                                    return (
                                        '<div class="plan-card' +
                                        (isPopular ? ' popular' : '') +
                                        '">' +
                                        (isPopular
                                            ? '<div class="plan-popular-badge"><i data-lucide="star"></i> Beliebt</div>'
                                            : '') +
                                        '<div class="plan-name">' +
                                        esc(p.label) +
                                        '</div>' +
                                        '<div class="plan-desc">' +
                                        esc(p.description || '') +
                                        '</div>' +
                                        priceHtml +
                                        '<ul class="plan-features">' +
                                        feats
                                            .map(function (f) {
                                                return '<li>' + esc(f) + '</li>';
                                            })
                                            .join('') +
                                        '</ul>' +
                                        '<button class="btn btn-primary" style="margin-top: auto;justify-content:center" onclick="openOrderModalById(\'' +
                                        esc(p.plan_id) +
                                        '\')">' +
                                        (price === 0 ? 'Kostenlos starten' : 'Jetzt bestellen') +
                                        '</button>' +
                                        '</div>'
                                    );
                                })
                                .join('') +
                            '</div>';
                    })
                    .catch(function (e) {
                        el.innerHTML =
                            '<div style="color:var(--accent2)">Fehler: ' +
                            esc(e.message || String(e)) +
                            '</div>';
                    });
            }

            function openOrderModalById(planId) {
                openOrderModal(_shopPlansMap[planId]);
            }

            function openOrderModal(plan) {
                if (!plan) return;
                _selectedPlan = plan;
                var price = parseFloat(plan.price) || 0;
                document.getElementById('order-plan-info').innerHTML =
                    '<strong>' +
                    esc(plan.label) +
                    '</strong> &mdash; ' +
                    (price === 0
                        ? '<span style="color:var(--accent3)">Kostenlos</span>'
                        : '<span style="color:var(--accent);font-weight:700">' +
                          price.toFixed(2) +
                          ' € / Jahr</span>') +
                    '<br><span style="color:var(--text2)">' +
                    esc(plan.description || '') +
                    '</span>';
                document.getElementById('order-domain').value = '';
                document.getElementById('order-alert').innerHTML = '';
                document.getElementById('order-confirm-btn').disabled = false;
                document.getElementById('order-modal').classList.add('open');
                setTimeout(function () {
                    document.getElementById('order-domain').focus();
                }, 100);
            }

            function closeOrderModal() {
                document.getElementById('order-modal').classList.remove('open');
                _selectedPlan = null;
            }

            function confirmOrder() {
                if (!_selectedPlan) return;
                var domain = document.getElementById('order-domain').value.trim();
                if (!domain) {
                    document.getElementById('order-domain').style.borderColor = 'var(--accent2)';
                    document.getElementById('order-alert').innerHTML =
                        '<div style="color:var(--accent2);font-size: var(--text-sm);">Bitte Domain eingeben.</div>';
                    return;
                }
                var btn = document.getElementById('order-confirm-btn');
                btn.disabled = true;
                btn.textContent = 'Wird übermittelt…';
                API('/licenses/book', {
                    method: 'POST',
                    body: JSON.stringify({ plan_id: _selectedPlan.plan_id, domain: domain }),
                })
                    .then(function (d) {
                        closeOrderModal();
                        document.getElementById('shop-content').innerHTML =
                            '<div style="background:rgba(95,191,106,.1);border:1px solid rgba(95,191,106,.3);border-radius: var(--radius-lg);padding: var(--space-6);max-width:480px;">' +
                            '<h3 style="color:var(--accent3);margin-bottom: var(--space-2);display:flex;align-items:center;gap:.45rem"><i data-lucide="check-circle"></i> Bestellung eingegangen!</h3>' +
                            '<p style="color:var(--text);margin-bottom: var(--space-3);">Deine Lizenz wurde reserviert. Du erhältst in Kürze eine Rechnung per E-Mail.</p>' +
                            '<p style="font-size: var(--text-sm);color:var(--text2);">Lizenz-Key: <code style="background:var(--bg3);padding: .1rem var(--space-2);border-radius: var(--radius-sm);">' +
                            esc(d.license_key) +
                            '</code></p>' +
                            '<p style="font-size: var(--text-sm);color:var(--text2);margin-top: var(--space-2);">Die Lizenz wird nach Zahlungseingang aktiviert.</p>' +
                            '<button class="btn btn-ghost btn-sm" style="margin-top: var(--space-4)" onclick="switchTab(\'licenses\')"><i data-lucide="key-round"></i> Zu meinen Lizenzen</button>' +
                            '</div>';
                    })
                    .catch(function (e) {
                        btn.disabled = false;
                        btn.innerHTML = '<i data-lucide="check"></i> Verbindlich bestellen';
                        document.getElementById('order-alert').innerHTML =
                            '<div style="color:var(--accent2);font-size: var(--text-sm);margin-top: var(--space-2);">' +
                            esc(e.message || 'Fehler beim Bestellen.') +
                            '</div>';
                    });
            }

            // Klick außerhalb modal schließt es
            document.addEventListener('click', function (e) {
                var modal = document.getElementById('order-modal');
                if (modal && modal.classList.contains('open') && e.target === modal)
                    closeOrderModal();
                var umodal = document.getElementById('upgrade-modal');
                if (umodal && umodal.classList.contains('open') && e.target === umodal)
                    closeUpgradeModal();
            });

            // ── Portal-Rechnungen ─────────────────────────────────────────────────────────
            function loadPortalInvoices() {
                var el = document.getElementById('portal-inv-list');
                el.innerHTML = '<div class="loading"><div class="spinner"></div></div>';
                API('/invoices')
                    .then(function (d) {
                        var invs = d.invoices || [];
                        if (!invs.length) {
                            el.innerHTML =
                                '<div class="loading" style="color:var(--text2)">Noch keine Rechnungen vorhanden.</div>';
                            return;
                        }
                        el.innerHTML =
                            '<div class="table-wrap"><table class="data-table"><thead><tr>' +
                            '<th>Nummer</th><th>Datum</th><th>Betrag</th><th>Fällig</th><th>Status</th><th></th>' +
                            '</tr></thead><tbody>' +
                            invs
                                .map(function (inv) {
                                    var statusColor =
                                        {
                                            draft: 'var(--text2)',
                                            sent: 'var(--accent)',
                                            overdue: 'var(--accent2)',
                                            paid: 'var(--accent3)',
                                            cancelled: 'var(--text2)',
                                        }[inv.status] || 'var(--text2)';
                                    var statusLabel =
                                        {
                                            draft: 'Entwurf',
                                            sent: 'Offen',
                                            overdue: 'Überfällig',
                                            paid: 'Bezahlt',
                                            cancelled: 'Storniert',
                                        }[inv.status] || inv.status;
                                    return (
                                        '<tr>' +
                                        '<td><strong>' +
                                        esc(inv.invoice_number || '–') +
                                        '</strong></td>' +
                                        '<td>' +
                                        fmtDateShort(inv.created_at) +
                                        '</td>' +
                                        '<td><strong>' +
                                        (parseFloat(inv.amount_gross) || 0).toFixed(2) +
                                        ' €</strong></td>' +
                                        '<td>' +
                                        (inv.due_date ? fmtDateShort(inv.due_date) : '–') +
                                        '</td>' +
                                        '<td><span style="color:' +
                                        statusColor +
                                        ';font-weight: 500;font-size: var(--text-sm);">' +
                                        esc(statusLabel) +
                                        '</span></td>' +
                                        '<td>' +
                                        (inv.pdf_path || inv.id
                                            ? '<button class="btn btn-ghost btn-sm" onclick="downloadInv(\'' +
                                              esc(inv.id) +
                                              "','" +
                                              esc(inv.invoice_number || inv.id) +
                                              '\')"><i data-lucide="file-text"></i> PDF</button>'
                                            : '') +
                                        '</td>' +
                                        '</tr>'
                                    );
                                })
                                .join('') +
                            '</tbody></table></div>';
                    })
                    .catch(function (e) {
                        el.innerHTML =
                            '<div style="color:var(--accent2);">Fehler: ' +
                            esc(e.message || String(e)) +
                            '</div>';
                    });
            }

            function downloadInv(id, num) {
                fetch('/api/portal/invoices/' + encodeURIComponent(id) + '/pdf', {
                    headers: { Authorization: 'Bearer ' + TOKEN },
                })
                    .then(function (r) {
                        if (!r.ok) throw new Error('PDF nicht verfügbar');
                        return r.blob();
                    })
                    .then(function (b) {
                        var u = URL.createObjectURL(b);
                        var a = document.createElement('a');
                        a.href = u;
                        a.download = 'Rechnung-' + num + '.pdf';
                        document.body.appendChild(a);
                        a.click();
                        a.remove();
                        setTimeout(function () {
                            URL.revokeObjectURL(u);
                        }, 2000);
                    })
                    .catch(function (e) {
                        toast(e.message || 'PDF nicht verfügbar', 'error');
                    });
            }

