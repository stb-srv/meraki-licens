                                          '<td><code style="font-size: var(--text-sm)">' +
                                          esc((h.license_key || '').slice(0, 18)) +
                                          '&hellip;</code></td>' +
                                          '<td><span class="badge badge-' +
                                          esc(h.plan) +
                                          '">' +
                                          esc(h.plan) +
                                          '</span></td>' +
                                          '<td><span class="badge badge-' +
                                          esc(h.action) +
                                          '">' +
                                          esc(h.action) +
                                          '</span></td>' +
                                          '<td style="font-weight: 500;color:' +
                                          (h.amount ? 'var(--accent3)' : 'var(--text2)') +
                                          '">' +
                                          fmtEur(h.amount) +
                                          '</td>' +
                                          '<td style="font-size: var(--text-sm);max-width:180px">' +
                                          esc(h.note || '—') +
                                          '</td>' +
                                          '</tr>'
                                      );
                                  })
                                  .join('') +
                              '</tbody></table>'
                            : '<div class="loading" style="padding: var(--space-8)">Keine Einträge.</div>';
                    })
                    .catch(function (e) {
                        document.getElementById('hist-table').innerHTML =
                            '<div class="alert alert-error" style="margin: var(--space-4)">' +
                            esc(e.message || 'Fehler') +
                            '</div>';
                    });
            }

            // ── Konto ─────────────────────────────────────────────────────────────────────
            function loadAccount() {
                API('/me')
                    .then(function (d) {
                        var c = d.customer;
                        document.getElementById('account-content').innerHTML =
                            '<div class="card">' +
                            '<div class="card-title"><i data-lucide="user"></i> Kontodaten</div>' +
                            '<table style="width:100%;border-collapse:collapse;font-size: var(--text-sm)">' +
                            '<tr><td style="padding: var(--space-2) 0;color:var(--text2);width:140px">Name</td><td style="padding: var(--space-2) 0;font-weight: 500">' +
                            esc(c.name) +
                            '</td></tr>' +
                            '<tr><td style="padding: var(--space-2) 0;color:var(--text2)">E-Mail</td><td style="padding: var(--space-2) 0">' +
                            esc(c.email) +
                            '</td></tr>' +
                            (c.company
                                ? '<tr><td style="padding: var(--space-2) 0;color:var(--text2)">Firma</td><td style="padding: var(--space-2) 0">' +
                                  esc(c.company) +
                                  '</td></tr>'
                                : '') +
                            (c.phone
                                ? '<tr><td style="padding: var(--space-2) 0;color:var(--text2)">Telefon</td><td style="padding: var(--space-2) 0">' +
                                  esc(c.phone) +
                                  '</td></tr>'
                                : '') +
                            '<tr><td style="padding: var(--space-2) 0;color:var(--text2)">Zahlungsstatus</td><td style="padding: var(--space-2) 0"><span class="badge badge-' +
                            (c.payment_status === 'paid' ? 'active' : 'revoked') +
                            '">' +
                            esc(c.payment_status) +
                            '</span></td></tr>' +
                            '<tr><td style="padding: var(--space-2) 0;color:var(--text2)">Kunde seit</td><td style="padding: var(--space-2) 0">' +
                            fmtDateShort(c.created_at) +
                            '</td></tr>' +
                            '</table>' +
                            '<p style="margin-top: var(--space-4);font-size: var(--text-sm);color:var(--text2)">Möchtest du deine Daten ändern? Bitte kontaktiere uns direkt.</p>' +
                            '</div>' +
                            '<div class="card" style="margin-top: var(--space-4)">' +
                            '<div class="card-title"><i data-lucide="key-round"></i> Passwort ändern</div>' +
                            '<div id="account-pass-alert"></div>' +
                            '<div class="form-group"><label>Aktuelles Passwort</label><input type="password" id="acc-pass-curr"></div>' +
                            '<div class="form-group"><label>Neues Passwort (min. 10 Zeichen)</label><input type="password" id="acc-pass-new"></div>' +
                            '<div class="form-group"><label>Neues Passwort wiederholen</label><input type="password" id="acc-pass-new2"></div>' +
                            '<button class="btn btn-primary btn-sm" onclick="doChangePasswordVoluntary()">Passwort aktualisieren</button>' +
                            '</div>';
                    })
                    .catch(function (e) {
                        document.getElementById('account-content').innerHTML =
                            '<div class="alert alert-error">' +
                            esc(e.message || 'Fehler') +
                            '</div>';
                    });
            }

            function doChangePasswordVoluntary() {
                var curr = document.getElementById('acc-pass-curr').value;
                var newp = document.getElementById('acc-pass-new').value;
                var newp2 = document.getElementById('acc-pass-new2').value;
                if (!curr || !newp || !newp2) {
                    showAlert('account-pass-alert', 'Bitte alle Felder ausfüllen.', 'error');
                    return;
                }
                if (newp.length < 10) {
                    showAlert(
                        'account-pass-alert',
                        'Das neue Passwort muss mindestens 10 Zeichen haben.',
                        'error'
                    );
                    return;
                }
                if (newp !== newp2) {
                    showAlert(
                        'account-pass-alert',
                        'Die neuen Passwörter stimmen nicht überein.',
                        'error'
                    );
                    return;
                }
                if (curr === newp) {
                    showAlert(
                        'account-pass-alert',
                        'Das neue Passwort muss sich vom aktuellen unterscheiden.',
                        'error'
                    );
                    return;
                }

                showAlert('account-pass-alert', 'Passwort wird geändert...', 'info');

                API('/change-password', {
                    method: 'POST',
                    body: JSON.stringify({ current_password: curr, new_password: newp }),
                })
                    .then(function (d) {
                        showAlert(
                            'account-pass-alert',
                            '<i data-lucide="check-circle"></i> Passwort erfolgreich geändert.',
                            'success'
                        );
                        document.getElementById('acc-pass-curr').value = '';
                        document.getElementById('acc-pass-new').value = '';
                        document.getElementById('acc-pass-new2').value = '';
                    })
                    .catch(function (e) {
                        showAlert(
                            'account-pass-alert',
                            esc(e.message || 'Fehler beim Passwort-Ändern.'),
                            'error'
                        );
                    });
            }

            init();
        </script>

        <div id="toast-container"></div>

        <!-- Upgrade Modal -->
        <div id="upgrade-modal" class="modal-overlay">
            <div class="modal-box">
                <h3><i data-lucide="arrow-up-circle"></i> Lizenz upgraden</h3>
                <p
                    style="
                        color: var(--text2);
                        font-size: var(--text-sm);
                        margin-bottom: var(--space-4);
                    "
                >
                    Aktueller Plan: <strong id="upgrade-current-plan"></strong>
                </p>
                <div class="form-group">
                    <label>Neuer Plan</label>
                    <select
                        id="upgrade-plan-select"
                        style="
                            width: 100%;
                            background: var(--bg2);
                            border: 1px solid var(--border);
                            border-radius: var(--radius-md);
                            padding: var(--space-2) var(--space-3);
                            color: var(--text);
                            font-size: var(--text-sm);
                            outline: none;
                        "
                    >
                        <option value="STARTER">STARTER – 29 €/Jahr</option>
                        <option value="PRO">PRO – 59 €/Jahr</option>
                        <option value="PRO_PLUS">PRO_PLUS – 89 €/Jahr</option>
                        <option value="ENTERPRISE">ENTERPRISE – 199 €/Jahr</option>
                    </select>
                </div>
                <div id="upgrade-alert"></div>
                <div class="modal-footer">
                    <button class="btn btn-ghost btn-sm" onclick="closeUpgradeModal()">
                        Abbrechen
                    </button>
                    <button
                        class="btn btn-primary btn-sm"
                        id="upgrade-confirm-btn"
                        onclick="confirmUpgrade()"
                    >
                        <i data-lucide="arrow-up-circle"></i> Upgrade bestätigen
                    </button>
                </div>
            </div>
        </div>
        <script>
      import { createIcons, icons } from 'lucide';
      window.lucide = { createIcons: () => createIcons({ icons }) };
    </script>
    </body>
</html>
