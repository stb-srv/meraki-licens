---
/*
 * Setup wizard page — ported 1:1 from public/setup.html (lift-and-shift).
 * First-run wizard: checks /api/v1/setup-status, then creates the superadmin via
 * /api/v1/setup.
 *
 * Changes vs the original:
 *   - Duplicated :root/[data-theme] token block removed; tokens come from the
 *     global tokens.css imported by BaseLayout.
 *   - CDN Lucide replaced by tree-shaken initIcons() (only this page's icons).
 *   - <style> is is:global because alerts/markup are injected at runtime via
 *     innerHTML and would not get Astro's scoped attributes; the inline spinner
 *     also references the global @keyframes spin.
 *   - onclick/oninput handlers exposed on window (module scripts are scoped).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
---

<BaseLayout title="Meraki – Setup">
    <Header>
        <button class="theme-toggle" onclick="toggleTheme()" title="Theme wechseln">
            <i data-lucide="sun"></i>
        </button>
    </Header>

    <div class="center-wrap">
        <div class="setup-card">
            <!-- Loading -->
            <div
                id="view-loading"
                class="card-body"
                style="text-align: center; padding: var(--space-12) var(--space-8)"
            >
                <div
                    style="width: 38px; height: 38px; border: 3px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto var(--space-4);"
                >
                </div>
                <div style="color: var(--text2); font-size: var(--text-sm)">
                    Setup-Status wird geprüft…
                </div>
            </div>

            <!-- Already done -->
            <div id="view-done" class="done-card" style="display: none">
                <div class="done-icon"><i data-lucide="check-circle-2"></i></div>
                <div class="done-title">Setup bereits abgeschlossen</div>
                <div class="done-sub">
                    Der Admin-Account existiert bereits.<br />Du kannst dich jetzt einloggen.
                </div>
                <a
                    href="/"
                    class="btn btn-primary"
                    style="display: inline-flex; width: auto; padding: var(--space-3) var(--space-8);"
                    ><i data-lucide="log-in"></i> Zum Admin-Panel</a
                >
            </div>

            <!-- Wizard -->
            <div id="view-wizard" style="display: none">
                <div class="card-header">
                    <div class="card-header-row">
                        <div class="card-icon"><i data-lucide="settings-2"></i></div>
                        <div>
                            <div class="card-title">Ersteinrichtung</div>
                            <div class="card-sub">Schritt <span id="step-num">1</span> von 2</div>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="step-indicator">
                        <div class="step-dot active" id="sdot-1"></div>
                        <div class="step-dot" id="sdot-2"></div>
                        <span class="step-label" id="step-label">Überblick</span>
                    </div>

                    <!-- Step 1 -->
                    <div id="step-1">
                        <div class="alert alert-success" style="margin-bottom: var(--space-4)">
                            <i data-lucide="check-circle-2"></i>
                            <div>
                                <strong>Automatisch konfiguriert</strong><br />Alle Secrets wurden
                                generiert und in
                                <code style="font-family: var(--font-mono); font-size: var(--text-sm)"
                                    >.env</code
                                >
                                gespeichert.
                            </div>
                        </div>
                        <ul class="checklist">
                            <li><i data-lucide="check"></i> ADMIN_SECRET generiert (HS256 / RS256)</li>
                            <li>
                                <i data-lucide="check"></i> HMAC_SECRET generiert (Offline-Token Signing)
                            </li>
                            <li>
                                <i data-lucide="check"></i> PORTAL_SECRET generiert (Kunden-Portal JWT)
                            </li>
                            <li><i data-lucide="check"></i> RSA-Schlüsselpaar generiert (2048-bit)</li>
                            <li><i data-lucide="check"></i> Datenbank-Migrationen ausgeführt</li>
                        </ul>
                        <hr class="divider" />
                        <div
                            style="font-size: var(--text-sm); color: var(--text2); margin-bottom: var(--space-4);"
                        >
                            Im nächsten Schritt erstellst du deinen <strong>Superadmin-Account</strong>.
                        </div>
                        <button class="btn btn-primary" onclick="goStep(2)">
                            Weiter <i data-lucide="arrow-right"></i>
                        </button>
                    </div>

                    <!-- Step 2 -->
                    <div id="step-2" style="display: none">
                        <div id="wizard-alert"></div>
                        <div class="form-group">
                            <label>Benutzername</label>
                            <input
                                type="text"
                                id="inp-username"
                                placeholder="admin"
                                autocomplete="username"
                                autocapitalize="none"
                                spellcheck="false"
                            />
                        </div>
                        <div class="form-group">
                            <label
                                >Passwort
                                <span style="color: var(--text2); font-weight: 400"
                                    >(min. 12 Zeichen)</span
                                ></label
                            >
                            <input
                                type="password"
                                id="inp-password"
                                placeholder="••••••••••••"
                                autocomplete="new-password"
                                oninput="updateStrength()"
                            />
                            <div class="pw-strength">
                                <div class="pw-strength-bar" id="pw-bar"></div>
                            </div>
                            <div class="pw-hint" id="pw-hint"></div>
                        </div>
                        <div class="form-group">
                            <label>Passwort bestätigen</label>
                            <input
                                type="password"
                                id="inp-confirm"
                                placeholder="••••••••••••"
                                autocomplete="new-password"
                            />
                        </div>
                        <button class="btn btn-primary" id="btn-create" onclick="createAdmin()">
                            Admin-Account erstellen
                        </button>
                    </div>
                </div>
            </div>

            <!-- Success -->
            <div id="view-success" style="display: none">
                <div class="card-body">
                    <div class="success-icon"><i data-lucide="check-circle-2"></i></div>
                    <div class="success-title">Setup abgeschlossen!</div>
                    <div class="success-sub">
                        Superadmin-Account erfolgreich erstellt.<br />Du wirst gleich zum Admin-Panel
                        weitergeleitet.
                    </div>
                    <a href="/" class="btn btn-primary"
                        ><i data-lucide="layout-dashboard"></i> Zum Admin-Panel</a
                    >
                    <div class="countdown">
                        Automatische Weiterleitung in <span id="countdown-sec">5</span>s
                    </div>
                </div>
            </div>
        </div>
    </div>
</BaseLayout>

<style is:global>
    /* Page base styles ported from public/setup.html (minus the token block). */
    body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-body);
        line-height: 1.6;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        transition:
            background 0.3s,
            color 0.3s;
    }
    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
        font-family: var(--font-display);
        letter-spacing: -0.02em;
        line-height: 1.2;
    }
    input,
    button,
    select,
    textarea {
        font-family: var(--font-body);
    }
    .lucide {
        width: 1.05em;
        height: 1.05em;
        vertical-align: -0.18em;
        stroke-width: 2;
        flex-shrink: 0;
    }

    nav {
        position: sticky;
        top: 0;
        z-index: 100;
        background: var(--nav-bg);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
        padding: 0 var(--space-8);
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 60px;
    }
    .nav-logo {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        font-size: var(--text-base);
        font-weight: 700;
        color: var(--accent);
    }
    .nav-logo .lucide {
        width: 1.15em;
        height: 1.15em;
    }
    .theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text2);
        border-radius: var(--radius-md);
        width: 34px;
        height: 34px;
        cursor: pointer;
        transition: all 0.2s;
    }
    .theme-toggle:hover {
        border-color: var(--accent);
        color: var(--accent);
    }

    .center-wrap {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: var(--space-8);
        background-image:
            radial-gradient(ellipse 80% 60% at 50% -10%, rgba(0, 191, 165, 0.1), transparent),
            linear-gradient(var(--grid-line) 1px, transparent 1px),
            linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
        background-size:
            100% 100%,
            40px 40px,
            40px 40px;
    }

    .setup-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        width: 100%;
        max-width: 460px;
        box-shadow: var(--shadow);
        overflow: hidden;
    }
    .card-header {
        padding: var(--space-6) var(--space-8) var(--space-6);
        border-bottom: 1px solid var(--border);
    }
    .card-header-row {
        display: flex;
        align-items: center;
        gap: 0.7rem;
    }
    .card-icon {
        width: 38px;
        height: 38px;
        border-radius: var(--radius-lg);
        background: var(--accent-dim);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .card-icon .lucide {
        color: var(--accent);
        width: 1.2em;
        height: 1.2em;
    }
    .card-title {
        font-size: var(--text-lg);
        font-weight: 700;
    }
    .card-sub {
        color: var(--text2);
        font-size: var(--text-sm);
        margin-top: 0.1rem;
    }

    .card-body {
        padding: var(--space-6) var(--space-8) var(--space-8);
    }

    .step-indicator {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        margin-bottom: var(--space-6);
    }
    .step-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--border);
        transition: background 0.3s;
    }
    .step-dot.active {
        background: var(--accent);
    }
    .step-dot.done {
        background: var(--accent3);
    }
    .step-label {
        font-size: var(--text-xs);
        color: var(--text2);
        margin-left: var(--space-1);
    }

    .form-group {
        margin-bottom: var(--space-4);
    }
    .form-group label {
        display: block;
        font-size: var(--text-sm);
        color: var(--text2);
        margin-bottom: var(--space-1);
        font-weight: 500;
    }
    .form-group input {
        width: 100%;
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: var(--space-2) var(--space-4);
        color: var(--text);
        font-size: var(--text-sm);
        outline: none;
        transition: border-color 0.2s;
        font-family: var(--font-body);
    }
    .form-group input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px var(--accent-dim);
    }

    .pw-strength {
        height: 3px;
        border-radius: 2px;
        margin-top: var(--space-2);
        background: var(--border);
        overflow: hidden;
    }
    .pw-strength-bar {
        height: 100%;
        width: 0;
        border-radius: 2px;
        transition:
            width 0.3s,
            background 0.3s;
    }
    .pw-hint {
        font-size: var(--text-xs);
        color: var(--text2);
        margin-top: var(--space-1);
        min-height: 1.1em;
    }

    .btn {
        display: inline-flex;
        justify-content: center;
        align-items: center;
        gap: 0.4rem;
        padding: var(--space-3) var(--space-4);
        border-radius: var(--radius-md);
        border: none;
        cursor: pointer;
        font-size: var(--text-sm);
        font-weight: 500;
        transition: all var(--transition-interactive);
        text-decoration: none;
        width: 100%;
        font-family: var(--font-body);
        margin-top: var(--space-1);
    }
    .btn-primary {
        background: var(--accent);
        color: #fff;
    }
    .btn-primary:hover:not(:disabled) {
        background: var(--accent-hover);
    }
    .btn-primary:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .alert {
        display: flex;
        align-items: flex-start;
        gap: 0.45rem;
        padding: var(--space-3) var(--space-4);
        border-radius: var(--radius-md);
        font-size: var(--text-sm);
        margin-bottom: var(--space-4);
        line-height: 1.5;
    }
    .alert .lucide {
        flex-shrink: 0;
        margin-top: 0.05em;
    }
    .alert-error {
        background: rgba(255, 93, 108, 0.1);
        border: 1px solid rgba(255, 93, 108, 0.25);
        color: var(--accent2);
    }
    .alert-success {
        background: rgba(95, 191, 106, 0.1);
        border: 1px solid rgba(95, 191, 106, 0.25);
        color: var(--accent3);
    }
    .alert-info {
        background: var(--accent-dim);
        border: 1px solid rgba(0, 191, 165, 0.25);
        color: var(--accent);
    }
    .alert-warn {
        background: rgba(255, 190, 60, 0.1);
        border: 1px solid rgba(255, 190, 60, 0.25);
        color: #fbbf24;
    }

    .checklist {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: var(--space-6);
    }
    .checklist li {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        font-size: var(--text-sm);
        color: var(--text2);
    }
    .checklist li .lucide {
        color: var(--accent3);
        width: 0.95em;
        height: 0.95em;
        flex-shrink: 0;
    }

    .divider {
        border: none;
        border-top: 1px solid var(--border);
        margin: var(--space-3) 0 var(--space-4);
    }

    .success-icon {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: rgba(95, 191, 106, 0.15);
        border: 2px solid rgba(95, 191, 106, 0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto var(--space-6);
    }
    .success-icon .lucide {
        color: var(--accent3);
        width: 1.6em;
        height: 1.6em;
    }
    .success-title {
        text-align: center;
        font-size: var(--text-lg);
        font-weight: 700;
        margin-bottom: var(--space-1);
    }
    .success-sub {
        text-align: center;
        font-size: var(--text-sm);
        color: var(--text2);
        margin-bottom: var(--space-6);
    }
    .countdown {
        text-align: center;
        font-size: var(--text-sm);
        color: var(--text2);
        margin-top: var(--space-2);
    }
    .countdown span {
        color: var(--accent);
        font-weight: 700;
    }

    .spinner {
        display: inline-block;
        width: 1em;
        height: 1em;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.6s linear infinite;
        vertical-align: -0.15em;
    }
    @keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .done-card {
        text-align: center;
        padding: var(--space-10) var(--space-8);
    }
    .done-card .done-icon {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: var(--accent-dim);
        border: 2px solid rgba(0, 191, 165, 0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto var(--space-4);
    }
    .done-card .done-icon .lucide {
        color: var(--accent);
        width: 1.5em;
        height: 1.5em;
    }
    .done-title {
        font-size: var(--text-base);
        font-weight: 700;
        margin-bottom: var(--space-2);
    }
    .done-sub {
        color: var(--text2);
        font-size: var(--text-sm);
        margin-bottom: var(--space-6);
    }
</style>

<script>
    import { makeIconRenderer } from '../lib/icons.js';
    import {
        Zap,
        Sun,
        CheckCircle2,
        LogIn,
        Settings2,
        Check,
        ArrowRight,
        LayoutDashboard,
        AlertCircle,
        Info,
        AlertTriangle,
    } from 'lucide';

    // Only the icons this page actually uses.
    const initIcons = makeIconRenderer({
        Zap,
        Sun,
        CheckCircle2,
        LogIn,
        Settings2,
        Check,
        ArrowRight,
        LayoutDashboard,
        AlertCircle,
        Info,
        AlertTriangle,
    });

    function toggleTheme() {
        const cur = document.documentElement.getAttribute('data-theme');
        const next = cur === 'light' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        initIcons();
    }

    let setupToken = null;

    function show(id) {
        ['view-loading', 'view-done', 'view-wizard', 'view-success'].forEach(function (v) {
            const el = document.getElementById(v);
            if (el) el.style.display = v === id ? '' : 'none';
        });
    }

    function goStep(n) {
        document.getElementById('step-1').style.display = n === 1 ? '' : 'none';
        document.getElementById('step-2').style.display = n === 2 ? '' : 'none';
        document.getElementById('step-num').textContent = n;
        document.getElementById('sdot-1').className = 'step-dot' + (n > 1 ? ' done' : ' active');
        document.getElementById('sdot-2').className = 'step-dot' + (n === 2 ? ' active' : '');
        const labels = ['', 'Überblick', 'Admin erstellen'];
        document.getElementById('step-label').textContent = labels[n] || '';
        if (n === 2) setTimeout(() => document.getElementById('inp-username').focus(), 50);
        initIcons();
    }

    function updateStrength() {
        const pw = document.getElementById('inp-password').value;
        const bar = document.getElementById('pw-bar');
        const hint = document.getElementById('pw-hint');
        let score = 0;
        if (pw.length >= 12) score++;
        if (/[A-Z]/.test(pw)) score++;
        if (/[0-9]/.test(pw)) score++;
        if (/[^A-Za-z0-9]/.test(pw)) score++;
        const colors = ['', '#ff5d6c', '#fbbf24', '#00bfa5', '#5fbf6a'];
        const hints = ['', 'Zu schwach', 'Schwach', 'Gut', 'Sehr stark'];
        bar.style.width = pw.length ? `${score * 25}%` : '0';
        bar.style.background = colors[score] || '#ff5d6c';
        hint.textContent = pw.length ? hints[score] || '' : '';
        hint.style.color = colors[score] || '';
    }

    function setAlert(type, msg) {
        const icons = {
            error: 'alert-circle',
            success: 'check-circle-2',
            info: 'info',
            warn: 'alert-triangle',
        };
        document.getElementById('wizard-alert').innerHTML =
            `<div class="alert alert-${type}"><i data-lucide="${icons[type] || 'info'}"></i><div>${msg}</div></div>`;
        initIcons();
    }

    async function createAdmin() {
        document.getElementById('wizard-alert').innerHTML = '';
        const username = document.getElementById('inp-username').value.trim();
        const password = document.getElementById('inp-password').value;
        const confirm = document.getElementById('inp-confirm').value;

        if (!username) {
            setAlert('error', 'Benutzername ist ein Pflichtfeld.');
            return;
        }
        if (password.length < 12) {
            setAlert('error', 'Passwort muss mindestens 12 Zeichen haben.');
            return;
        }
        if (password !== confirm) {
            setAlert('error', 'Passwörter stimmen nicht überein.');
            return;
        }

        const btn = document.getElementById('btn-create');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner"></span> Wird erstellt…';

        try {
            const res = await fetch('/api/v1/setup', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ setup_token: setupToken, username, password }),
            });
            const data = await res.json();

            if (res.ok && data.success) {
                show('view-success');
                initIcons();
                let sec = 5;
                const t = setInterval(() => {
                    sec--;
                    const el = document.getElementById('countdown-sec');
                    if (el) el.textContent = sec;
                    if (sec <= 0) {
                        clearInterval(t);
                        window.location.href = '/';
                    }
                }, 1000);
            } else {
                setAlert('error', data.message || 'Fehler beim Erstellen des Accounts.');
                btn.disabled = false;
                btn.innerHTML = 'Admin-Account erstellen';
            }
        } catch {
            setAlert('error', 'Netzwerkfehler – ist der Server erreichbar?');
            btn.disabled = false;
            btn.innerHTML = 'Admin-Account erstellen';
        }
    }

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && document.getElementById('step-2').style.display !== 'none') {
            createAdmin();
        }
    });

    (async function init() {
        try {
            const res = await fetch('/api/v1/setup-status');
            const data = await res.json();
            if (!data.needed) {
                show('view-done');
            } else {
                setupToken = data.setup_token;
                show('view-wizard');
                goStep(1);
            }
        } catch {
            show('view-wizard');
            document.getElementById('wizard-alert').innerHTML =
                `<div class="alert alert-warn"><i data-lucide="alert-triangle"></i><div>Server nicht erreichbar. Stelle sicher, dass <code style="font-family:var(--font-mono)">npm start</code> läuft.</div></div>`;
            goStep(1);
        }
        initIcons();
    })();

    // Expose handlers referenced by inline onclick/oninput attributes.
    Object.assign(window, { toggleTheme, goStep, updateStrength, createAdmin });
</script>
