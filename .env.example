# Meraki License Server – .env Beispiel
# Kopiere diese Datei nach .env und passe die Werte an.

# Server
PORT=4000

# Datenbank (SQLite)
# Pfad zur SQLite-Datenbankdatei (Standard: ./data/licens.db)
DB_PATH=./data/licens.db

# Sicherheit (PFLICHT – niemals Default-Werte verwenden!)
ADMIN_SECRET=aendere_mich_sofort

# HMAC_SECRET: wird für Offline-Token-Signing (HS256) verwendet.
# SICHERHEITSHINWEIS: Muss mindestens 32 zufällige Zeichen haben!
# Empfehlung: openssl rand -hex 32
HMAC_SECRET=aendere_mich_sofort_hmac

# Kunden-Portal JWT Secret (PFLICHT für Portal-Funktion)
PORTAL_SECRET=aendere_mich_sofort_portal

# CORS – erlaubte Origins (kommagetrennt, z.B. https://meinrestaurant.de)
# Wenn leer: nur dynamisch aus DB-Lizenzen
CORS_ORIGINS=

# RSA JWT Signing (optional, empfohlen für Produktion)
# RSA_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...
# RSA_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...

# HMAC Signing für Lizenz-Validierung (optional)
# HMAC_SECRET_KEY=

# Setup-Endpoint (leer = deaktiviert)
SETUP_TOKEN=

# SMTP (optional – kann auch über Admin-Panel konfiguriert werden)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=dein@email.de
# SMTP_PASS=smtp_passwort
# SMTP_FROM=noreply@example.com

# Portal-URL (für Einladungslinks in E-Mails)
PORTAL_URL=https://deine-domain.de

# Initialer Superadmin-Passwort bei setup-db (leer = generiert zufälliges Passwort)
ADMIN_INIT_PASSWORD=

# Rechnungs-Speicherpfad
STORAGE_PATH=./storage

# App-URL (für Links in E-Mails)
APP_URL=http://localhost:3000

